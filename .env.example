# Garmin Connect credentials
GARMIN_EMAIL=
GARMIN_PASSWORD=
# Optional: directory where Garmin auth tokens are cached
GARMINTOKENS=

# Login retry tuning (optional)
GARMIN_LOGIN_RETRIES=3
GARMIN_LOGIN_BACKOFF_SECONDS=30

# Database connection
# Local development defaults to SQLite when unset.
# For PostgreSQL (Neon/Render), use the full connection string, e.g.:
#   postgresql://user:password@host/dbname
# Bare postgres:// URLs are accepted and normalized automatically.
DATABASE_URL=sqlite:///endurolytics.db

# Athlete thresholds used by the training-load calculations.
# Bike TSS uses FTP (watts).
ATHLETE_FTP_WATTS=
# Run TSS uses threshold pace in seconds per kilometer.
ATHLETE_RUN_THRESHOLD_PACE_SECONDS_PER_KM=
# Swim TSS uses critical swim speed pace in seconds per 100 meters.
ATHLETE_SWIM_CSS_PACE_SECONDS_PER_100M=
# Heart-rate reference points.
ATHLETE_MAX_HR=
ATHLETE_RESTING_HR=
ATHLETE_THRESHOLD_HR=
